	<# } else { #>
		<# if ( data.length > 0 ) { #>
			<fieldset class="component_option_radio_buttons_fieldset">
				<legend class="component_option_radio_buttons_legend screen-reader-text">{{data.title}}</legend>
				<span class="select_label">
